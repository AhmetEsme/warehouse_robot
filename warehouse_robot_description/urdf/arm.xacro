<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="common_properties.xacro"/>

  <!-- PROPERTIES -->
  <xacro:property name="arm_base_length" value="0.08"/>
  <xacro:property name="arm_base_width" value="0.08"/>
  <xacro:property name="arm_base_height" value="0.02"/>
  <xacro:property name="lower_arm_radius" value="0.02"/>
  <xacro:property name="lower_arm_length" value="0.25"/>
  <xacro:property name="upper_arm_radius" value="0.02"/>
  <xacro:property name="upper_arm_length" value="0.20"/>
  <xacro:property name="gripper_length" value="0.05"/>
  <xacro:property name="gripper_width" value="0.05"/>
  <xacro:property name="gripper_height" value="0.05"/>
  


    <!-- BASE FOOTPRINT (standalone test için) -->
  <link name="base_footprint"/>

  <!-- ARM BASE LINK -->
  <link name="arm_base_link">
    <visual>
      <geometry>
        <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}"/>
      </geometry>
      <origin xyz="0 0 ${arm_base_height/2}" rpy="0 0 0"/>
      <material name="orange">
        <color rgba="1 0.44 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}"/>
      </geometry>
      <origin xyz="0 0 ${arm_base_height/2}" rpy="0 0 0"/>
    </collision>
    <xacro:inertial_box mass="5.0" x="${arm_base_length}" y="${arm_base_width}" z="${arm_base_height}"/>
  </link>

  <gazebo reference="arm_base_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <!-- LOWER_ARM LINK -->
  <link name="lower_arm_link">
    <visual>
      <geometry>
        <cylinder radius="${lower_arm_radius}" length="${lower_arm_length}"/>
      </geometry>
      <origin xyz="0 0 ${lower_arm_length/2}" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${lower_arm_radius}" length="${lower_arm_length}"/>
      </geometry>
      <origin xyz="0 0 ${lower_arm_length/2}" rpy="0 0 0"/>
    </collision>
    <xacro:inertial_cylinder mass="0.3" radius="${lower_arm_radius}" length="${lower_arm_length}"/>
  </link>

  <gazebo reference="lower_arm_link">
    <material>Gazebo/Blue</material>
  </gazebo>


  <!-- UPPER_ARM LINK -->
  <link name="upper_arm_link">
    <visual>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <origin xyz="0 0 ${upper_arm_length/2}" rpy="0 0 0"/>
      <material name="Green">
        <color rgba="0.3 0.69 0.31 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <origin xyz="0 0 ${upper_arm_length/2}" rpy="0 0 0"/>
    </collision>
    <xacro:inertial_cylinder mass="0.3" radius="${upper_arm_radius}" length="${upper_arm_length}"/>
  </link>

  <gazebo reference="upper_arm_link">
    <material>Gazebo/Green</material>
  </gazebo>




  <!-- GRIIPER LINK -->
  <link name="gripper_link">
    <visual>
      <geometry>
        <box size="${gripper_length} ${gripper_width} ${gripper_height}"/>
      </geometry>
      <origin xyz="0 0 ${gripper_height/2}" rpy="0 0 0"/>
      <material name="Yellow">
        <color rgba="0.8 0.86 0.22 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${gripper_length} ${gripper_width} ${gripper_height}"/>
      </geometry>
      <origin xyz="0 0 ${gripper_height/2}" rpy="0 0 0"/>
    </collision>
    <xacro:inertial_box mass="0.1" x="${gripper_length}" y="${gripper_width}" z="${gripper_height}"/>
  </link>

  <gazebo reference="gripper_link">
    <material>Gazebo/Yellow</material>
  </gazebo>

  <!-- ARM BASE JOINT (fixed, standalone test için) -->
  <joint name="arm_base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 ${arm_base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ARM BASE → LOWERARM -->
  <joint name="arm_base_to_lower_arm" type="revolute">
    <parent link="arm_base_link"/>
    <child link="lower_arm_link"/>
    <origin xyz="0 0 ${arm_base_height}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="${pi/2}" effort="100" velocity="100"/>
    <dynamics friction="0.05" damping="0.1"/>
  </joint>

  <!-- LOWERARM → UPPERARM -->
  <joint name="lower_arm_to_upper_arm" type="revolute">
    <parent link="lower_arm_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 ${lower_arm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="${pi/2}" effort="100" velocity="100"/>
    <dynamics friction="0.05" damping="0.1"/>
  </joint>

   <!-- UPPERARM → GRIPPER -->
  <joint name="upper_arm_to_gripper" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 ${upper_arm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="${pi/2}" effort="100" velocity="100"/>
    <dynamics friction="0.05" damping="0.1"/>
  </joint>

  

</robot>